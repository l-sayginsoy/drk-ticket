# (Optional, aktuell in der App ungenutzt – Daten laufen über Firebase)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Brevo (E-Mails): nur in .env.local, nicht committen.
# Production: gleicher Name als GitHub Actions Secret, sonst sendet der Build keine Mails.
VITE_BREVO_API_KEY=
# Absender: muss in Brevo unter „Senders & IPs“ als verifizierte Absender-Adresse existieren (sonst HTTP 400).
# Wenn leer, nutzt die App noreply@drk-ticket.de — dann diese Domain in Brevo anlegen/verifizieren oder hier setzen:
# VITE_BREVO_SENDER_EMAIL=deine-verifizierte@domain.de
# VITE_BREVO_SENDER_NAME=DRK Haustechnik Service
